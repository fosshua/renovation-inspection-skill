{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RenovationInspectionResult",
  "type": "object",
  "required": [
    "overall_assessment",
    "stage_assessment",
    "urgent_next_steps",
    "findings",
    "evidence_gaps",
    "limitations"
  ],
  "properties": {
    "overall_assessment": {
      "type": "string",
      "description": "Concise summary of observed construction quality and risk."
    },
    "stage_assessment": {
      "type": "object",
      "required": ["primary_stage", "confidence"],
      "properties": {
        "primary_stage": {
          "type": "object",
          "required": ["stage_id", "stage_name"],
          "properties": {
            "stage_id": { "type": "string" },
            "stage_name": { "type": "string" }
          }
        },
        "secondary_stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stage_id", "stage_name"],
            "properties": {
              "stage_id": { "type": "string" },
              "stage_name": { "type": "string" }
            }
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "stage_rationale": { "type": "string" },
        "stage_source_gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "urgent_next_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_pack_assessment": {
      "type": "object",
      "properties": {
        "completeness": {
          "type": "string",
          "enum": ["complete", "partial", "insufficient"]
        },
        "available_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "measurement_reliability": {
          "type": "string",
          "enum": ["high", "medium", "low", "not_applicable"]
        },
        "project_agreement_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "classification_notes": { "type": "string" }
      }
    },
    "inspection_completeness": {
      "type": "object",
      "properties": {
        "checked_required_checks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unverified_required_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "needed_evidence"],
            "properties": {
              "check": { "type": "string" },
              "needed_evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocks_next_stage": { "type": "boolean" }
            }
          }
        },
        "summary": { "type": "string" }
      }
    },
    "next_shot_guidance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["purpose", "instructions"],
        "properties": {
          "purpose": { "type": "string" },
          "instructions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "evidence_refs",
          "observed_evidence",
          "risk",
          "reference_basis",
          "recommendation",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string" },
          "stage_id": { "type": "string" },
          "stage_name": { "type": "string" },
          "evidence_strength": {
            "type": "string",
            "enum": ["confirmed", "suspected", "not_verifiable"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": {
            "type": "string",
            "enum": [
              "safety",
              "standards_compliance",
              "waterproofing",
              "plumbing",
              "electrical",
              "gas",
              "fire_safety",
              "tiling",
              "flooring",
              "wall_ceiling",
              "carpentry",
              "paint",
              "protection",
              "sequencing",
              "material",
              "workmanship",
              "other"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Examples: image_1, image_2, video_1@00:12, text_1."
            },
            "minItems": 1
          },
          "observed_evidence": { "type": "string" },
          "risk": { "type": "string" },
          "severity_rationale": { "type": "string" },
          "common_issue_match": {
            "type": "object",
            "properties": {
              "matched": { "type": "boolean" },
              "pattern": { "type": "string" },
              "stage_reference": { "type": "string" }
            }
          },
          "shortcut_pattern_match": {
            "type": "object",
            "properties": {
              "matched": { "type": "boolean" },
              "pattern_id": { "type": "string" },
              "name": { "type": "string" },
              "risk": { "type": "string" }
            }
          },
          "stage_gate_risk": {
            "type": "object",
            "properties": {
              "blocks_next_stage": { "type": "boolean" },
              "next_stage": { "type": "string" },
              "reason": { "type": "string" }
            }
          },
          "reference_basis": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "name", "applicability", "confidence"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "national_standard",
                    "industry_standard",
                    "local_rule",
                    "enterprise_benchmark",
                    "reference_image_comparison",
                    "visual_practical_judgment"
                  ]
                },
                "number": { "type": "string" },
                "name": { "type": "string" },
                "version_or_date": { "type": "string" },
                "citation": { "type": "string" },
                "applicability": { "type": "string" },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                }
              }
            }
          },
          "recommendation": { "type": "string" },
          "rectification": {
            "type": "object",
            "properties": {
              "action": { "type": "string" },
              "likely_responsible_party": { "type": "string" },
              "reinspection_evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocks_next_stage": { "type": "boolean" }
            }
          },
          "professional_escalation": { "type": "boolean" },
          "needed_additional_evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "evidence_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
