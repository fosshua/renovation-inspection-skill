{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RenovationInspectionResult",
  "type": "object",
  "required": [
    "overall_assessment",
    "urgent_next_steps",
    "findings",
    "evidence_gaps",
    "limitations"
  ],
  "properties": {
    "overall_assessment": {
      "type": "string",
      "description": "Concise summary of observed construction quality and risk."
    },
    "urgent_next_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "category",
          "evidence_refs",
          "observed_evidence",
          "risk",
          "reference_basis",
          "recommendation",
          "confidence"
        ],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": {
            "type": "string",
            "enum": [
              "safety",
              "standards_compliance",
              "waterproofing",
              "plumbing",
              "electrical",
              "gas",
              "fire_safety",
              "tiling",
              "flooring",
              "wall_ceiling",
              "carpentry",
              "paint",
              "protection",
              "sequencing",
              "material",
              "workmanship",
              "other"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Examples: image_1, image_2, video_1@00:12."
            },
            "minItems": 1
          },
          "observed_evidence": { "type": "string" },
          "risk": { "type": "string" },
          "severity_rationale": { "type": "string" },
          "reference_basis": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "name", "applicability", "confidence"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "national_standard",
                    "industry_standard",
                    "local_rule",
                    "enterprise_benchmark",
                    "reference_image_comparison",
                    "visual_practical_judgment"
                  ]
                },
                "number": { "type": "string" },
                "name": { "type": "string" },
                "version_or_date": { "type": "string" },
                "citation": { "type": "string" },
                "applicability": { "type": "string" },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                }
              }
            }
          },
          "recommendation": { "type": "string" },
          "professional_escalation": { "type": "boolean" },
          "needed_additional_evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "evidence_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
